# Personal SLM Configuration - Fully Offline, No External APIs Required

# Memory Settings
memory__vector_db=faiss
memory__persist_directory=./data/memory
memory__embedding_model=sentence-transformers/all-MiniLM-L6-v2

# Web Search Settings (optional - requires external API)
web_search__enabled=false
web_search__serpapi_key=serp_api_key

# Evaluation Settings
evaluation__max_iterations=5
evaluation__min_improvement=0.05

# Logging Settings
logging__level=INFO
logging__log_file=./logs/agent_system.log
